# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Database (XAMPP MySQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=indiekraf_db

# ─── CMS Auth ────────────────────────────────────────────────
# Secret key untuk JWT token (ganti dengan string acak yang kuat)
JWT_SECRET=indiekraf-cms-secret-2024-change-me

# ─── SMTP Email Configuration (Nodemailer) ───────────────────
# Tentukan konfigurasi SMTP untuk mengirim notifikasi formulir
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=no-reply@indiekraf.com
SMTP_FROM_NAME="Indiekraf Website"

