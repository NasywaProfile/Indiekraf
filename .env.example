# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Database (XAMPP MySQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=indiekraf_db

# ─── CMS Auth ────────────────────────────────────────────────
# Secret key untuk JWT token (ganti dengan string acak yang kuat)
JWT_SECRET=indiekraf-cms-secret-2024-change-me
